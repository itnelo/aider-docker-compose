#            ipv4_address: 172.20.10.1
#    environment:
#      LOCAL_HOST: ${SSH_TUNNEL_OLLAMA_LOCAL_HOST}
#      LOCAL_PORT: ${SSH_TUNNEL_OLLAMA_LOCAL_PORT}
#      REMOTE_HOST: ${SSH_TUNNEL_OLLAMA_REMOTE_HOST}
#      REMOTE_PORT: ${SSH_TUNNEL_OLLAMA_REMOTE_PORT}
#      SSH_TUNNEL_HOST: ${SSH_TUNNEL_OLLAMA_SSH_TUNNEL_HOST}
#      SSH_TUNNEL_PORT: ${SSH_TUNNEL_OLLAMA_SSH_TUNNEL_PORT}
