#
# Aider docker-compose (dockerized)
#
# This is a TEMPLATE. Copy it to `.env` and edit values:
#
#   cp .env-template .env
#
# All variables are documented here to keep `docker-compose.dev.yml.dist` as a stable template.
#

#
# Project / compose
#

# Optional: set a fixed compose project name (so container/network names are predictable).
# If empty, docker compose derives it from the directory name.
COMPOSE_PROJECT_NAME=aider-docker-compose

#
# Host user mapping
#

# Run containers as your host UID/GID so that generated/modified files in bind-mounted workspaces
# are owned by you (no root-owned artifacts).
#
# Get values with:
#   id -u
#   id -g
HOST_UID=1000
HOST_GID=1000

# Timezone inside containers (mostly for logs; Aider itself doesn't require it).
TIMEZONE=Europe/Moscow

#
# Aider container image
#

# Docker image tag for `paulgauthier/aider-full`.
#
# Upstream docs: https://aider.chat/docs/install/docker.html
AIDER_VERSION=v0.86.2

#
# Workspace & persistence (host paths)
#

# Persistent home for Aider inside the container, mounted as `/app` (which is also image default `HOME`).
# This directory will store:
# - `.aider*` files (history, config, caches)
# - Generated `.aider.model.settings.yml` (so generation parameters persist)
AIDER_HOME_PATH=./data/agent/app

# Directory on the host where you keep target repositories for the `agent` service.
# We mount this path into the Aider container as `/workspaces`.
AIDER_WORKSPACES_PATH=./data/agent/workspaces

# Which workspace subdir is used as the default working directory for `docker compose run agent ...`.
# This becomes the container `WORKDIR`.
AIDER_WORKSPACE_DEFAULT=default

# Git identity (inside the `agent` container)
AIDER_GIT_AUTHOR_NAME=Git User
AIDER_GIT_AUTHOR_EMAIL=git_user@example.com
AIDER_GIT_COMMITTER_NAME=Git User
AIDER_GIT_COMMITTER_EMAIL=git_user@example.com

#
# Ollama connectivity
#

# Base URL where the `agent` service (Aider) should reach the Ollama HTTP API.
#
# 1) Local Ollama exposed on THIS host:
#    - Ollama compose exposes port 11434 on the host.
#
#    Example:
#      AIDER_OLLAMA_API_BASE=http://172.20.0.1:11434
#
# 2) Remote Ollama server in your LAN, reachable ONLY over SSH:
#
#      AIDER_OLLAMA_API_BASE=http://ssh-tunnel-ollama:11434
#
AIDER_OLLAMA_API_BASE=http://172.20.0.1:11434

# Optional: API key for Ollama endpoints which require authentication.
# Default empty.
# Upstream Aider docs: https://aider.chat/docs/llms/ollama.html
AIDER_OLLAMA_API_KEY=

#
# Aider model selection (Ollama)
#

# Provider prefix used by Aider.
#
# - `ollama_chat` is recommended by Aider docs because Aider is a multi-turn agent and chat format
#   is more robust for system/user/assistant roles and long-context interactions.
# - `ollama` is closer to `/api/generate` style and may work, but is typically less stable for agent workflows.
#
# Upstream Aider docs: https://aider.chat/docs/llms/ollama.html
AIDER_OLLAMA_PROVIDER=ollama_chat

# The Ollama model name as known to your Ollama server.
# Example:
#   omnicoder-9b-gguf
AIDER_OLLAMA_MODEL=omnicoder-9b-gguf

# Model used for "weak" tasks (commit messages, chat history summarization).
# Equivalent CLI flag: `--weak-model ...`
#
# For Ollama, specify a full aider model string, e.g.:
#   ollama_chat/qwen2.5-coder:7b
# If empty, aider chooses a default (depends on your main `--model`).
AIDER_WEAK_MODEL=ollama_chat/omnicoder-9b-gguf

# Editor model (architect pipeline).
AIDER_EDITOR_MODEL=ollama_chat/omnicoder-9b-gguf

# Stream LLM output to the console (`AIDER_STREAM`). false is friendlier for non-TTY `docker compose run`.
AIDER_STREAM=false

# Fancy terminal input (history, completion). false for headless containers (`AIDER_FANCY_INPUT`).
AIDER_FANCY_INPUT=false

# Colorized Rich panels (`--pretty` / `AIDER_PRETTY`). false = plainer, shorter logs under docker compose run.
AIDER_PRETTY=false

# Terminal bell when the LLM finishes (`AIDER_NOTIFICATIONS`).
AIDER_NOTIFICATIONS=false

# Max tokens of model "thinking" / reasoning stream that Aider may show (`--thinking-tokens` / `AIDER_THINKING_TOKENS`).
# 0 = hide that block (shortest logs). Set a positive integer to allow a visible reasoning panel: larger = more
# room for the model to expose chain-of-thought before the final answer (more console output and latency).
# Provider caveat: some backends (e.g. ollama_chat + many GGUF) do not implement Aider's thinking_tokens; Aider may
# warn "does not support 'thinking_tokens', ignoring" and this variable has no effect. Log lines like THINKING/ANSWER
# can still appear when the model prints them as ordinary completion text, not as Aider's suppressible side channel.
AIDER_THINKING_TOKENS=0

# Chat UI language and auto-generated commit message language (BCP-47 tags, e.g. ru, en).
# Empty = Aider default (follows system locale). See `--chat-language` / `--commit-language`.
AIDER_CHAT_LANGUAGE=ru
AIDER_COMMIT_LANGUAGE=ru

# Custom instructions for the LLM when Aider generates a commit message (`--commit-prompt` / AIDER_COMMIT_PROMPT).
# Empty = built-in Aider prompt. Non-empty overrides; empty value is unset in entrypoint so defaults are preserved.
AIDER_COMMIT_PROMPT=

# Auto-commit LLM edits (`--auto-commits` / `AIDER_AUTO_COMMITS`). Used by raw `docker compose run … agent …`.
# The `bin/agent` wrapper overrides per run: default forces no auto-commit; pass `--commit` to force auto-commit.
AIDER_AUTO_COMMITS=false

# Enable "architect" edit format for the main chat.
# Equivalent CLI flag: `--architect`
# Upstream: https://aider.chat/docs/more/architect.html (if this URL changes, search "aider architect edit format")
AIDER_ARCHITECT=0

# Auto-accept architect changes.
# Equivalent CLI flags:
# - `--auto-accept-architect`  (true)
# - `--no-auto-accept-architect` (false)
#
# Default in aider may be True; set to false to require confirmation.
AIDER_AUTO_ACCEPT_ARCHITECT=false

# Append `Co-authored-by: aider ...` to commit messages when attributing AI edits.
# Set to false to omit that trailer (equivalent CLI: `--no-attribute-co-authored-by`).
AIDER_ATTRIBUTE_CO_AUTHORED_BY=false

# When true (aider default), rewrites git author/committer to show AI attribution (e.g. name becomes
# "Your Name (aider)"). Set false so commits use `GIT_AUTHOR_*` / `GIT_COMMITTER_*` from the environment
# without extra decoration (`--no-attribute-author`, `--no-attribute-committer`).
AIDER_ATTRIBUTE_AUTHOR=false
AIDER_ATTRIBUTE_COMMITTER=false

# Privacy / telemetry (PostHog, etc.)
AIDER_ANALYTICS_DISABLE=true
AIDER_ANALYTICS=false

#
# Aider -> Ollama generation parameters (forwarded as Ollama `options`)
#
# These variables are used to generate `.aider.model.settings.yml` for Aider, so that Aider always
# passes consistent parameters to Ollama.
#
# Notes:
# - Increasing context window and max tokens increases RAM/VRAM usage and latency.
# - Start conservative, then increase as needed.
#

# `num_ctx`: context window (tokens).
# Bigger values reduce the risk of silent truncation for long prompts / repo contexts.
# Typical steps: 8192 -> 16384 -> 32768.
AIDER_OLLAMA_NUM_CTX=16384

# `num_predict`: max tokens to generate for the reply (like "max_tokens").
# Lower = shorter/faster, higher = longer/slower. Typical: 256..2048.
AIDER_OLLAMA_NUM_PREDICT=1024

# `temperature`: randomness.
# For coding/edits keep low (0.0..0.3). Higher values can increase creativity but also hallucinations.
AIDER_OLLAMA_TEMPERATURE=0.2

# `top_p` (nucleus sampling): smaller values narrow choices, increasing determinism.
# Common defaults: 0.8..1.0. Leave empty to use server/model defaults.
AIDER_OLLAMA_TOP_P=

# `top_k`: smaller values narrow choices; leave empty to use defaults.
AIDER_OLLAMA_TOP_K=

# `repeat_penalty`: penalty for repeating tokens; can reduce loops. Leave empty for defaults.
AIDER_OLLAMA_REPEAT_PENALTY=

# `seed`: fixed seed for reproducibility. Leave empty if you don't need deterministic runs.
AIDER_OLLAMA_SEED=

# `keep_alive`: keep model loaded in Ollama memory between requests (reduces cold-start latency).
# Values like: "5m", "30m", "1h", "-1" (forever). Leave empty to use defaults.
AIDER_OLLAMA_KEEP_ALIVE=30m

#
# Post-edit lint (optional)
#
# `AIDER_LINT_CMD` is expanded by the agent entrypoint into one or more `aider --lint-cmd` flags:
#   - Single rule:     AIDER_LINT_CMD='php: php -l'
#   - Multiple rules:  use ';;' between pairs (must not appear inside a command), e.g.
#       AIDER_LINT_CMD='php: php -l;;javascript: npx eslint --max-warnings=0'
#   - Or use a multiline value in compose (YAML `|`), one `lang: command` per line.
# The `aider-full` image may not ship PHP/node; install tools in a custom image or run lint on the host.
# AIDER_AUTO_LINT / `aider --lint` — see upstream `aider --help`.
# AIDER_AUTO_LINT=true
# AIDER_LINT_CMD=php: php -l

#
# SSH tunnel to remote Ollama
#

# Path to private SSH key on the host, mounted read-only into the tunnel container.
SSH_TUNNEL_OLLAMA_SSH_KEY_PATH=/dev/null

# Remote SSH server (the machine you connect to over SSH).
# For LAN server: IP like `192.168.1.50`.
SSH_TUNNEL_OLLAMA_SSH_TUNNEL_HOST=_

# SSH port on the remote server.
SSH_TUNNEL_OLLAMA_SSH_TUNNEL_PORT=22

# SSH user on the remote server.
SSH_TUNNEL_OLLAMA_SSH_TUNNEL_USER=root

# Remote host/port of Ollama from the perspective of the SSH server.
# Often Ollama listens on 127.0.0.1:11434 on that server.
SSH_TUNNEL_OLLAMA_REMOTE_HOST=127.0.0.1
SSH_TUNNEL_OLLAMA_REMOTE_PORT=11434

# Local host/port presented by the tunnel container inside docker network.
# `LOCAL_HOST` can usually stay `*` (bind all).
SSH_TUNNEL_OLLAMA_LOCAL_HOST=*
SSH_TUNNEL_OLLAMA_LOCAL_PORT=11434
